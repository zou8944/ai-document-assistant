# LLM 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# Embedding 配置（不填则复用 LLM 的 Key 和 Base URL）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-ada-002

# PostgreSQL 配置（供 docker compose 的 postgres 服务使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_document_assistant

# 数据库连接（本地开发使用；docker compose 会自动构造此值）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_document_assistant

# Chroma 配置（本地开发留空；docker compose 会通过 environment 注入）
CHROMA_HOST=
CHROMA_PORT=8000
ANONYMIZED_TELEMETRY=FALSE

# 应用配置
LOG_LEVEL=info
