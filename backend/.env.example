# ── 本地开发专用配置（docker compose 不引用此文件） ──
#
# 生产部署请使用项目根目录的 .env.deploy

# ── Crawl LLM 配置（数据爬取/处理阶段使用，目前仅支持 openai） ──
CRAWL_PROVIDER=openai
CRAWL_API_KEY=your_api_key_here
CRAWL_BASE_URL=https://api.siliconflow.cn/v1
CRAWL_MODEL=gpt-4o

# ── Agent LLM 配置（聊天 Agent 使用，目前仅支持 anthropic） ──
AGENT_PROVIDER=anthropic
AGENT_API_KEY=your_anthropic_api_key_here
AGENT_BASE_URL=
AGENT_MODEL=claude-sonnet-4-20250514

# ── Embedding 配置（必填，目前仅支持 OpenAI 风格） ──
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-ada-002

# ── PostgreSQL 配置（仅本地开发使用） ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_document_assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Chroma 配置（仅本地开发使用） ──
CHROMA_HOST=
CHROMA_PORT=8000
ANONYMIZED_TELEMETRY=FALSE

# ── 应用配置 ──
LOG_LEVEL=info
