# ── 本地开发专用配置（docker compose 不引用此文件） ──
#
# 生产部署请使用项目根目录的 .env.deploy
#
# 注意：AI 相关配置（Crawl / Agent / Embedding）通过前端设置界面管理，
# 存储在数据库中，无需在此配置。以下仅列出本地开发必需的基础设施连接信息。

# ── PostgreSQL 配置 ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_document_assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Chroma 配置（留空则使用本地持久化存储，不连接 Docker 容器） ──
CHROMA_HOST=
CHROMA_PORT=8000

# ── 应用配置 ──
LOG_LEVEL=info
