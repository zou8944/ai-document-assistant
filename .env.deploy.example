# ── 生产/本地部署专用配置 ──
#
# 复制此文件为 .env.deploy 并填入你的 API Key：
#   cp .env.deploy.example .env.deploy
#
# docker compose 部署时会读取此文件，将 AI 配置注入到 backend 容器。
# 所有数据库/Chroma/部署相关配置已硬编码在 docker-compose.yml 中，无需在此配置。

# LLM 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# Embedding 配置（不填则复用 LLM 的 Key 和 Base URL）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-ada-002

# 应用配置
LOG_LEVEL=info
